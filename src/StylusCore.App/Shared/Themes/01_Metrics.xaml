<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ================================================================== -->
    <!-- GLOBAL DIMENSIONS & LAYOUT                                          -->
    <!-- ================================================================== -->

    <!-- Corner Radii (Canonical Set) -->
    <CornerRadius x:Key="Radius.Small">4</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">8</CornerRadius>
    <CornerRadius x:Key="Radius.Large">12</CornerRadius>
    <CornerRadius x:Key="Radius.XLarge">16</CornerRadius>

    <!-- Margins / Paddings (Spacing Tokens) -->
    <Thickness x:Key="Spacing.Small">4</Thickness>
    <Thickness x:Key="Spacing.Medium">8</Thickness>
    <Thickness x:Key="Spacing.Large">12</Thickness>
    <Thickness x:Key="Spacing.XLarge">16</Thickness>
    <Thickness x:Key="Spacing.XXLarge">24</Thickness>
    <Thickness x:Key="Spacing.XXXLarge">32</Thickness>
    <Thickness x:Key="Spacing.XXLarge.Horizontal">24,0</Thickness>
    <Thickness x:Key="Padding.Input">12,8</Thickness>
    
    <!-- Sizing -->
    <sys:Double x:Key="Control.Height.Small">36</sys:Double>
    <sys:Double x:Key="Control.Height.Medium">40</sys:Double>
    <sys:Double x:Key="Control.Height.Large">48</sys:Double>
    
    <sys:Double x:Key="Icon.Size.Small">16</sys:Double>
    <sys:Double x:Key="Icon.Size.Medium">24</sys:Double>
    <sys:Double x:Key="Icon.Size.Large">32</sys:Double>
    
    <sys:Double x:Key="Button.Height.Standard">32</sys:Double>
    <sys:Double x:Key="Input.Height.Standard">32</sys:Double>

    <!-- ================================================================== -->
    <!-- SHELL / SIDEBAR METRICS                                             -->
    <!-- ================================================================== -->

    <!-- Window Sizing -->
    <sys:Double x:Key="Shell.MainWindowWidth">1280</sys:Double>
    <sys:Double x:Key="Shell.MainWindowHeight">800</sys:Double>
    <sys:Double x:Key="Shell.MainWindowMinWidth">800</sys:Double>
    <sys:Double x:Key="Shell.MainWindowMinHeight">600</sys:Double>
    <Thickness x:Key="Shell.ResizeBorderThickness">5</Thickness>
    <Thickness x:Key="Shell.MainWindowContentBorderThickness">1,1,0,0</Thickness>

    <!-- Sidebar & Header -->
    <sys:Double x:Key="Shell.SidebarCollapsedWidth">48</sys:Double>
    <GridLength x:Key="Shell.SidebarCollapsedWidth.GL">48</GridLength>
    <sys:Double x:Key="Shell.SidebarExpandedWidth">160</sys:Double>
    <sys:Double x:Key="Shell.SidebarItemHeight">48</sys:Double>
    <GridLength x:Key="Shell.SidebarItemHeight.GL">48</GridLength>
    <sys:Double x:Key="Shell.IconSlotWidth">48</sys:Double>
    <sys:Double x:Key="Shell.HeaderHeight">48</sys:Double>
    <sys:Double x:Key="Shell.IconSize">20</sys:Double>
    <CornerRadius x:Key="Shell.SidebarCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="Shell.CloseButtonHoverRadius">0,8,0,0</CornerRadius>
    <Thickness x:Key="Sidebar.TextMargin">0,0,16,0</Thickness>
    <Thickness x:Key="Sidebar.ItemsMargin">0,8,0,0</Thickness>

    <!-- ================================================================== -->
    <!-- SECTIONS PANEL METRICS                                              -->
    <!-- ================================================================== -->

    <sys:Double x:Key="Editor.SectionsPanelDefaultWidth">250</sys:Double>
    <sys:Double x:Key="Editor.SectionsPanelMaxWidth">400</sys:Double>
    <sys:Double x:Key="Editor.SectionsPanelMinWidth">200</sys:Double>
    <!-- GridLength companion for ColumnDefinition.Width -->
    <GridLength x:Key="Editor.SectionsPanelDefaultWidth.GL">250</GridLength>
    <sys:Double x:Key="Editor.SectionsPanelCollapsedWidth">48</sys:Double>
    <sys:Double x:Key="Editor.PageThumbnailWidth">80</sys:Double>
    <sys:Double x:Key="Editor.PageThumbnailHeight">110</sys:Double>

    <!-- ================================================================== -->
    <!-- GLOBAL METRICS (MIGRATED FROM THEMES)                               -->
    <!-- ================================================================== -->
    
    <sys:Double x:Key="Ribbon.Height">120</sys:Double>
    <sys:Double x:Key="Ribbon.Height.Collapsed">40</sys:Double>

    <!-- ================================================================== -->
    <!-- LIBRARY VIEW METRICS                                                -->
    <!-- ================================================================== -->

    <Thickness x:Key="Library.PageMargin">32,16,32,32</Thickness>
    <sys:Double x:Key="Library.CardWidth">280</sys:Double>
    <sys:Double x:Key="Library.CardMinHeight">220</sys:Double>
    <sys:Double x:Key="Library.CoverHeight">96</sys:Double>
    <sys:Double x:Key="Library.HeaderHeight">80</sys:Double>
    <CornerRadius x:Key="Library.CardCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="Library.CardTopCornerRadius">16,16,0,0</CornerRadius>
    <CornerRadius x:Key="Library.ContentCornerRadius">16,0,0,0</CornerRadius>
    <Thickness x:Key="Library.ContentPadding">32</Thickness>
    <Thickness x:Key="Library.CardGap">8</Thickness>

    <!-- Search Box -->
    <sys:Double x:Key="SearchBox.Width">384</sys:Double>
    <sys:Double x:Key="SearchBox.Height">36</sys:Double>
    <CornerRadius x:Key="SearchBox.CornerRadius">12</CornerRadius>

    <!-- Empty State -->
    <sys:Double x:Key="EmptyState.IconContainerSize">96</sys:Double>
    <sys:Double x:Key="EmptyState.IconSize">40</sys:Double>

</ResourceDictionary>
